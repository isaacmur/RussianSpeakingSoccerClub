{
  "expo": {
    "name": "Weekend League",
    "slug": "weekend-league",
    "version": "0.1.0",
    "scheme": "weekendleague",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#060B13",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.weekendleague.app"
    },
    "android": {
      "package": "com.weekendleague.app",
      "adaptiveIcon": {
        "backgroundColor": "#060B13"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#060B13",
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
