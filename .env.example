# Copy to .env and fill in from the hosted Supabase project (supabase.com) —
# Dashboard → Project Settings → API. All backend work happens on the hosted
# project via the web dashboard; see PHASE1_SETUP.md for setup (incl. disabling
# email confirmation).
# These are safe to expose in the client bundle (anon key is RLS-gated).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Server-side only (never prefix with EXPO_PUBLIC_): used by Edge Functions.
# Hosted Edge Functions get this injected automatically — no need to set it here.
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
