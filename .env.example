# Copy to .env and fill in from your Supabase project settings (API section).
# These are safe to expose in the client bundle (anon key is RLS-gated).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Server-side only (never prefix with EXPO_PUBLIC_): used by Edge Functions.
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
